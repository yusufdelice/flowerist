// Lotus Çiçekçilik — Database Schema

generator client {
  provider = "prisma-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  price       Float
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  tags        String?
  images      String   @default("[]")
  featured    Boolean  @default(false)
  inStock     Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  image     String?
  sortOrder Int       @default(0)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Banner {
  id        String  @id @default(cuid())
  title     String
  subtitle  String?
  image     String
  link      String?
  active    Boolean @default(true)
  sortOrder Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteSettings {
  id         String  @id @default("main")
  phone      String?
  whatsapp   String?
  email      String?
  address    String?
  instagram  String?
  aboutText  String?
  footerText String?
  updatedAt  DateTime @updatedAt
}
